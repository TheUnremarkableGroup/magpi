# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your-bot-token-here

DISCORD_APPLICATION_ID=your-app-id-here

# The channel ID where Pi will listen and respond
# Right-click channel → Copy Channel ID (requires Developer Mode)
DISCORD_CHANNEL_ID=your-channel-id-here

# Optional: Comma-separated user IDs with admin privileges
# Admins can use /discordi stop and /discordi reset
DISCORD_ADMIN_IDS=

# Optional: Comma-separated user IDs allowed to DM the bot
# Leave empty to allow all DMs, or set to specific IDs to restrict
DISCORD_DM_ALLOWLIST=

# Optional: Allowed file MIME types for uploads (comma-separated)
DISCORD_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/gif,image/webp,text/plain

# Optional: Automatically create threads for messages (default: true)
DISCORD_AUTO_THREAD=true

# Optional: Max number of concurrent threads the bot will process (default: 10, max: 50)
DISCORD_MAX_CONCURRENT_THREADS=10

# Optional: Max file upload size in bytes (default: 10MB)
DISCORD_MAX_UPLOAD_SIZE=10485760

# Optional: Pi model to use (defaults to first available)
DISCORD_MODEL=

# Optional: Thinking level (off, minimal, low, medium, high, xhigh)
DISCORD_THINKING_LEVEL=

# Optional: Auto-archive duration in minutes for threads (default: 1440)
# Valid values: 60, 1440, 4320, 10080
DISCORD_THREAD_AUTO_ARCHIVE_DURATION=1440

# Optional: Verbose logging — logs thinking and tool calls to daemon log
# Set to "1" or "true" to enable. View with /discordi logs
DISCORD_VERBOSE=